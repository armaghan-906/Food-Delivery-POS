# Central database — PostgreSQL 16 (see docs/decisions.md ADR-008).
# Never point a till at this; SQLite is the till's only database.
DATABASE_URL="postgresql://pos:pos@localhost:5432/pos?schema=public"

# API
PORT=4000

# Device/session auth (JWT) — placeholder for Phase 3+.
JWT_SECRET="dev-only-change-me"
